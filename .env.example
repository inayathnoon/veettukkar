# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit actual credentials.

# Firebase is configured via google-services.json (Android).
# Download it from Firebase Console → Project Settings → Your apps → Android
# and place it at the project root as google-services.json

# Twilio WhatsApp (used in Cloud Functions only — never in the client)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Set TWILIO_SANDBOX_MODE=true for local dev — sends freeform messages (no template approval needed)
# Production must leave this unset (or false) and use approved Meta templates below
TWILIO_SANDBOX_MODE=true

# Twilio Content Template SIDs (after Meta approval)
# Template: veettukkar_job_alert — "New {{1}} job available on {{2}} near {{3}}. Open Veettukkar to accept."
TWILIO_TEMPLATE_JOB_ALERT=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Template: veettukkar_rating_reminder — "How was the {{1}} job today? Rate your worker in the Veettukkar app."
TWILIO_TEMPLATE_RATING_REMINDER=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DigiLocker API (used in Cloud Functions only)
DIGILOCKER_CLIENT_ID=your_digilocker_client_id
DIGILOCKER_CLIENT_SECRET=your_digilocker_client_secret
DIGILOCKER_REDIRECT_URI=https://asia-south1-veettukkar-prod.cloudfunctions.net/verifyAadhaarCallback

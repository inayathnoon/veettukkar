rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isWorker() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'worker';
    }

    function isHomeowner() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'homeowner';
    }

    // ─── Users ───────────────────────────────────────────────────────────────────

    match /users/{uid} {
      // Any authenticated user can read any user profile (for job cards)
      allow read: if isAuthenticated();
      // Only the user themselves can write their own profile
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // ─── Jobs ────────────────────────────────────────────────────────────────────

    match /jobs/{jobId} {
      // Any authenticated user can read jobs
      allow read: if isAuthenticated();
      // Only homeowners can create jobs
      allow create: if isHomeowner() &&
        request.resource.data.homeownerId == request.auth.uid;
      // Workers can update status to "confirmed"; homeowners can update their own jobs
      allow update: if isAuthenticated() && (
        // Homeowner updates their own job
        resource.data.homeownerId == request.auth.uid ||
        // Worker accepts job (status: open → confirmed)
        (isWorker() &&
         resource.data.status == 'open' &&
         request.resource.data.status == 'confirmed' &&
         request.resource.data.acceptedWorkerId == request.auth.uid)
      );
      allow delete: if false;
    }

    // ─── Ratings ─────────────────────────────────────────────────────────────────

    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      // Only the fromUid can create a rating for a job they were part of
      allow create: if isAuthenticated() &&
        request.resource.data.fromUid == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Notifications Queue ──────────────────────────────────────────────────────

    match /notifications_queue/{notifId} {
      // Cloud Functions manage this collection; no client access
      allow read: if false;
      allow write: if false;
    }
  }
}
